{
  "test_cases": [
    {
      "test_name": "Test 1: Sanity Check (Empty Input)",
      "clusterer_params": {
        "max_clusters": 10,
        "merge_threshold": 1.5,
        "semantic_weights": [1.0, 1.0]
      },
      "mock_semantic_costs": {},
      "input_detections": [],
      "expected_clusters": []
    },
    {
      "test_name": "Test 2: Sanity Check (Single Input)",
      "clusterer_params": {
        "max_clusters": 10,
        "merge_threshold": 1.5,
        "semantic_weights": [1.0, 1.0]
      },
      "mock_semantic_costs": {
        "person": { "person": 1.0 }
      },
      "input_detections": [
        { "box": [10, 10, 60, 60], "object_category": "person", "conf": 0.95 }
      ],
      "expected_clusters": [
        { "box": [10, 10, 60, 60], "object_category": "person", "conf": 0.95, "children": [] }
      ]
    },
    {
      "test_name": "Test 3: Proximity-Dominated Merge",
      "clusterer_params": {
        "max_clusters": 10,
        "merge_threshold": 1.5,
        "semantic_weights": [1.0, 1.0]
      },
      "mock_semantic_costs": {
        "person": { "person": 1.0, "horse": 1.0 },
        "horse": { "person": 1.0, "horse": 1.0 }
      },
      "input_detections": [
        { "box": [10, 10, 60, 60], "object_category": "person", "conf": 0.95 },
        { "box": [61, 10, 110, 60], "object_category": "person", "conf": 0.80 },
        { "box": [200, 200, 250, 250], "object_category": "horse", "conf": 0.88 }
      ],
      "expected_clusters": [
        {
          "box": [10, 10, 110, 60],
          "object_category": "person",
          "conf": 0.95,
          "children": [
            { "box": [10, 10, 60, 60], "object_category": "person", "conf": 0.95, "children": [] },
            { "box": [61, 10, 110, 60], "object_category": "person", "conf": 0.80, "children": [] }
          ]
        },
        { "box": [200, 200, 250, 250], "object_category": "horse", "conf": 0.88, "children": [] }
      ]
    },
    {
      "test_name": "Test 4: Size-Dominated Penalty (No Merge)",
      "clusterer_params": {
        "max_clusters": 10,
        "merge_threshold": 1.5,
        "semantic_weights": [1.0, 1.0]
      },
      "mock_semantic_costs": {
        "person": { "person": 1.0 }
      },
      "input_detections": [
        { "box": [10, 10, 30, 30], "object_category": "person", "conf": 0.95 },
        { "box": [10, 40, 110, 140], "object_category": "person", "conf": 0.80 }
      ],
      "expected_clusters": [
        { "box": [10, 10, 30, 30], "object_category": "person", "conf": 0.95, "children": [] },
        { "box": [10, 40, 110, 140], "object_category": "person", "conf": 0.80, "children": [] }
      ]
    },
    {
      "test_name": "Test 5: Semantic-Dominated Merge (Disjoint)",
      "clusterer_params": {
        "max_clusters": 10,
        "merge_threshold": 1.5,
        "semantic_weights": [1.0,1.0]
      },
      "mock_semantic_costs": {
        "person": { "person": 1.0, "horse": 0.1 },
        "horse": { "person": 0.1, "horse": 1.0 }
      },
      "input_detections": [
        { "box": [10, 10, 60, 60], "object_category": "person", "conf": 0.95 },
        { "box": [300, 300, 350, 350], "object_category": "horse", "conf": 0.88 }
      ],
      "expected_clusters": [
        {
          "box": [10, 10, 350, 350],
          "object_category": "person",
          "conf": 0.95,
          "children": [
            { "box": [10, 10, 60, 60], "object_category": "person", "conf": 0.95, "children": [] },
            { "box": [300, 300, 350, 350], "object_category": "horse", "conf": 0.88, "children": [] }
          ]
        }
      ]
    },
    {
      "test_name": "Test 6: max_clusters Parameter",
      "clusterer_params": {
        "max_clusters": 1,
        "merge_threshold": 2.0,
        "semantic_weights": [1.0, 1.0]
      },
      "mock_semantic_costs": {
        "person": { "person": 1.0 }
      },
      "input_detections": [
        { "box": [10, 10, 60, 60], "object_category": "person", "conf": 0.95 },
        { "box": [61, 10, 110, 60], "object_category": "person", "conf": 0.80 }
      ],
      "expected_clusters": [
        {
          "box": [10, 10, 110, 60],
          "object_category": "person",
          "conf": 0.95,
          "children": [
            { "box": [10, 10, 60, 60], "object_category": "person", "conf": 0.95, "children": [] },
            { "box": [61, 10, 110, 60], "object_category": "person", "conf": 0.80, "children": [] }
          ]
        }
      ]
    },
    {
      "test_name": "Test 7: merge_threshold Parameter (No Merge)",
      "clusterer_params": {
        "max_clusters": 10,
        "merge_threshold": 1.1,
        "semantic_weights": [1.0, 0.1, 0.1]
      },
      "mock_semantic_costs": {
        "person": { "person": 1.0 }
      },
      "input_detections": [
        { "box": [10, 10, 60, 60], "object_category": "person", "conf": 0.95 },
        { "box": [61, 10, 110, 60], "object_category": "person", "conf": 0.80 }
      ],
      "expected_clusters": [
        { "box": [10, 10, 60, 60], "object_category": "person", "conf": 0.95, "children": [] },
        { "box": [61, 10, 110, 60], "object_category": "person", "conf": 0.80, "children": [] }
      ]
    }
  ]
}