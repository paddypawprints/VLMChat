{
  "model": {
    "model_path": "HuggingFaceTB/SmolVLM2-256M-Instruct",
    "max_new_tokens": 1024,
    "eos_token_id": 198,
    "use_onnx": true,
    "onnx_base_path": "~/onnx",
    "clip_model_name": "MobileCLIP2-S0",
    "clip_pretrained_path": "/Users/patrick/Dev/VLMChat/src/models/MobileClip/ml-mobileclip/mobileclip2_s0.pt",
    "clip_model_kwargs": {
      "image_mean": [
        0,
        0,
        0
      ],
      "image_std": [
        1,
        1,
        1
      ]
    },
    "yolo_engine_path": "~/Dev/model-rt-build/platform/jetson/release_artifacts/yolov8n_fp16.engine",
    "clip_image_engine_path": "~/Dev/model-rt-build/platform/jetson/release_artifacts/image_fp16.engine",
    "clip_text_engine_path": "~/Dev/model-rt-build/platform/jetson/release_artifacts/text_fp16.engine",
    "special_tokens": {
      "end_of_utterance": "<end_of_utterance>"
    }
  },
  "conversation": {
    "max_pairs": 10,
    "max_images": 1,
    "history_format": "xml",
    "word_limit": 15
  },
  "clusterer": {
    "max_clusters": 4,
    "merge_threshold": 1.5,
    "proximity_weight": 1.0,
    "size_weight": 0.5,
    "semantic_pair_weight": 1.0,
    "semantic_single_weight": 0.5,
    "user_prompts": [
      "a group of people riding horses",
      "people on horseback",
      "riders on a trail"
    ]
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(levelname)s - %(message)s"
  },
  "metrics": {
    "enabled": true,
    "publish_frequency": 30,
    "max_instruments": 50
  },
  "paths": {
    "project_root": "None",
    "coco_labels_path": "assets/coco_labels.txt",
    "captured_images_dir": "captured_images",
    "pipeline_dirs": [
      "~/pipelines",
      "./pipelines"
    ],
    "metrics_file": "~/metrics.json"
  },
  "platform": "mac"
}