# Database connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edge_llm

# AI Service (for Docker Compose, this will be http://ai-service:8000)
AI_SERVICE_URL=http://localhost:8000

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# Infisical Secrets Management
# Generate encryption key: openssl rand -hex 32
INFISICAL_ENCRYPTION_KEY=change-this-to-random-64-char-hex
# Generate auth secret: openssl rand -base64 32
INFISICAL_AUTH_SECRET=change-this-to-random-32-char-string
# Service token (get from Infisical UI after setup)
INFISICAL_TOKEN=
