FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy application code
COPY client ./client
COPY server ./server
COPY shared ./shared
COPY vite.config.ts tsconfig.json ./

# Expose port
EXPOSE 5000

# Start the application - push schema first
CMD ["sh", "-c", "npm run db:push && npm run dev"]
