{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://edge-camera/schemas/metrics-config/v1.0.0/schema.json",
  "title": "Metrics Configuration",
  "description": "Device announces available metrics sessions and instruments",
  "type": "object",
  "required": ["sessions"],
  "properties": {
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "timeseries", "instruments"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Session name"
          },
          "timeseries": {
            "type": "string",
            "description": "Timeseries name"
          },
          "instruments": {
            "type": "array",
            "items": {
              "type": "object",
              "description": "Instrument definition from metrics system"
            }
          }
        }
      }
    }
  }
}
