{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://edge-camera/schemas/webrtc-signaling/v1.0.0/schema.json",
  "title": "WebRTC Signaling",
  "description": "WebRTC offer/answer/ICE signaling messages",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["offer", "answer", "ice"],
      "description": "Signaling message type"
    },
    "sdp": {
      "type": "string",
      "description": "Session Description Protocol (for offer/answer)"
    },
    "candidate": {
      "type": "object",
      "description": "ICE candidate (for ice type)",
      "properties": {
        "candidate": {
          "type": "string"
        },
        "sdpMid": {
          "type": "string"
        },
        "sdpMLineIndex": {
          "type": "number"
        }
      }
    },
    "request_id": {
      "type": "string",
      "description": "Request identifier for matching responses"
    }
  }
}
