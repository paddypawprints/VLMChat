graph LR
    subgraph "Input"
        Camera[Camera Source<br/>GStreamer/libcamera/OpenCV]
    end
    
    subgraph "Detection Stage"
        YOLO[YOLO Detection<br/>80 COCO Categories<br/>PyTorch/TensorRT]
        Attributes[PA100K Model<br/>26 Attributes<br/>ONNX Runtime]
        Colors[Color Extraction<br/>HSV Analysis<br/>Region-based]
    end
    
    subgraph "Processing Stage"
        Cluster[Clusterer<br/>Merge Similar<br/>Detections]
        Tracker[Tracker<br/>Multi-frame<br/>Object Identity]
        Filter[Filter<br/>Category + Attribute<br/>+ Color Masks]
    end
    
    subgraph "Output Stage"
        AlertSink[Alert Sink<br/>Confirmed<br/>Detections]
        MQTTSink[MQTT Sink<br/>Publish to<br/>Platform]
        Display[Display Sink<br/>Visualization]
    end
    
    Camera -->|Frame| YOLO
    YOLO -->|Bounding Boxes| Attributes
    YOLO -->|Bounding Boxes| Colors
    Attributes -->|Classification| Cluster
    Colors -->|Color Data| Cluster
    Cluster -->|Merged Objects| Tracker
    Tracker -->|Tracked Objects| Filter
    Filter -->|Matching Objects| AlertSink
    Filter -->|Matching Objects| MQTTSink
    Filter -->|All Objects| Display
    
